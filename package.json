{
  "name": "td-manage",
  "version": "0.1.0",
  "private": true,
  "description": "本地 Web 版 TDengine 可视化数据管理工具。",
  "scripts": {
    "dev": "pnpm --parallel --filter @td-manage/server --filter @td-manage/web dev",
    "dev:server": "pnpm --filter @td-manage/server dev",
    "dev:web": "pnpm --filter @td-manage/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
